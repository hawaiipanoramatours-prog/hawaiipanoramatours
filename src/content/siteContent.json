  "about": {
    "photo": "About%20me%20pic.jpg",
    "headline": { "de": "Aloha! Ich bin Nasia 🌺", "en": "Aloha! I’m Nasia 🌺" },
    "paras": [
      {
        "de": "Seit vielen Jahren lebe ich auf Hawaiʻi und kenne die Inseln nicht nur als Reiseziel, sondern als Zuhause.",
        "en": "I’ve lived in Hawaiʻi for many years and know the islands not just as a destination, but as my home."
      },
      {
        "de": "Ich begleite meine Gäste persönlich – von der individuellen Planung bis zur Zeit vor Ort – und lege großen Wert auf authentische Erlebnisse abseits von Massentourismus.",
        "en": "I personally support my guests from the planning stage through their time on the islands, with a strong focus on authentic experiences away from mass tourism."
      },
      {
        "de": "Durch lokale Kontakte und eigene Erfahrung entstehen Reisen, die sich entspannt, stimmig und besonders anfühlen.",
        "en": "With strong local connections and firsthand experience, I create journeys that feel relaxed, well-balanced, and truly special."
      },
      {
        "de": "Mein Anspruch ist es, Ihnen Sicherheit, Orientierung und echte Insider-Einblicke zu geben – damit Sie Hawaiʻi bewusst und in Ihrem eigenen Tempo erleben können.",
        "en": "My goal is to provide clarity, confidence, and genuine local insight—so you can experience Hawaiʻi at your own pace."
      }
    ]
  },

